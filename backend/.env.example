# Copia este archivo a backend/.env y completa los valores.
# NO subas backend/.env al repositorio (está en .gitignore).

# --- OAuth Google ---
# Crea un cliente OAuth en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth/callback
FRONTEND_URL=http://localhost:8080

# Clave para firmar la sesión. Genera una con:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambia_esto_por_una_clave_aleatoria

# Restringe el registro a un dominio de correo (por defecto: ulasalle.edu.pe)
ALLOWED_EMAIL_DOMAIN=ulasalle.edu.pe

# --- Bases de datos ---
# En Docker, el compose sobreescribe estas URLs para apuntar a los contenedores.
POSTGRES_URL=postgresql://readuls:readuls123@localhost:5435/readuls
MONGO_URL=mongodb://localhost:27017
MONGO_DB=readuls
# Timeout de selección de servidor (ms). En prod (Atlas) deja 10000; en local
# puedes bajarlo a 2000 para que el arranque sin Mongo falle rápido.
MONGO_TIMEOUT_MS=10000

# --- Almacenamiento de imágenes (MinIO local, S3-compatible) ---
# En Docker, AWS_S3_ENDPOINT se sobreescribe a http://minio:9000.
# La URL pública = base + key. Para MinIO la base incluye el bucket (path-style);
# para R2/S3 con dominio ligado al bucket, la base NO lleva el bucket.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=readuls
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_PUBLIC_URL=http://localhost:9000/readuls
